{
  "contamination_flags": {
    "HAS_HOWTO_MARKERS": {
      "pattern": "installer|monter|d[ée]monter|d[ée]poser|remonter",
      "weight": 35,
      "excluded_roles": ["R3_CONSEILS", "R5_DIAGNOSTIC"]
    },
    "HAS_DIAG_MARKERS": {
      "pattern": "sympt[oô]me|panne|diagnostic",
      "weight": 35,
      "trigger_roles": ["R1_ROUTER"]
    },
    "HAS_VEHICLE_EXAMPLES": {
      "pattern": "(?:renault|peugeot|citro[eë]n|volkswagen|bmw|audi|mercedes|ford|opel|toyota|fiat|hyundai|dacia)\\s+(?:clio|megane|208|308|c3|c4|golf|polo|serie|classe|focus|fiesta|corsa|yaris|punto|i[23]0|sandero|duster)",
      "weight": 25,
      "excluded_roles": ["R4_REFERENCE", "R5_DIAGNOSTIC"]
    },
    "HAS_PRICE_PUSH": {
      "pattern": "prix|tarif|\\u20ac|EUR|co[uû]t(?:e|er|ant)?|budget|pas cher|meilleur prix|promotion",
      "weight": 20,
      "excluded_roles": ["R2_PRODUCT"]
    },
    "HAS_ABSOLUTE_CLAIMS": {
      "pattern": "(?:toujours|jamais|z[ée]ro|aucun(?:e)?)\\s+(?:panne|probl[eè]me|risque|d[ée]faut|usure)|garanti(?:e)?\\s+(?:à vie|illimit[ée]e)|infaillible",
      "weight": 20,
      "excluded_roles": []
    },
    "HAS_UNSOURCED_NUMBERS": {
      "pattern": "(?:(?:en moyenne|environ|pr[eè]s de|jusqu['''`]?[aà])\\s+)?\\d{2,}\\s*(?:%|pour cent|km|euros?|\\u20ac|ann[ée]es?|mois|heures?)",
      "weight": 25,
      "trigger_roles": ["R1_ROUTER", "R3_GUIDE", "R4_REFERENCE"]
    }
  },
  "table_safety_flags": {
    "TABLE_HAS_IMPERATIVES": {
      "pattern": "\\b(remplacez|installez|d[ée]montez|d[ée]posez)\\b",
      "weight": 15
    },
    "TABLE_HAS_STEP_SEQUENCE": {
      "pattern": "(?:^|\\|)\\s*[123]\\.\\s",
      "weight": 15
    }
  },
