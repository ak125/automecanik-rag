# AutoMecanik RAG Service - Environment Variables
# Version 100% gratuite (sans API payantes)

# Environment (dev, staging, prod)
ENV=dev
DEBUG=true

# Weaviate Vector Database
WEAVIATE_URL=http://weaviate:8080

# Redis Cache
REDIS_URL=redis://redis:6379

# API Security Key (générez une clé sécurisée)
RAG_API_KEY=your-secure-api-key-here

# Embeddings (sentence-transformers - GRATUIT)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Knowledge Corpus Path
KNOWLEDGE_PATH=/knowledge

# RAG Settings
RETRIEVAL_TOP_K=5
RETRIEVAL_ALPHA=0.7

# ========== Phase F.5 (ADR-031) — Runtime Hardening ==========
# Source canonique de la mémoire documentaire = automecanik-wiki/exports/rag/
# Voir governance-vault/ledger/knowledge/adr-031-migration-runbook §"Phase F.5"

# Mode d'écriture documentaire (défaut: readonly)
# - readonly = bloque CRUD admin documentaire, retourne 410 Gone
# - legacy   = mode exception encadré (cf. 4 vars ci-dessous)
RAG_WRITE_MODE=readonly

# Source d'ingestion canonique (défaut: wiki_exports_only)
RAG_INDEX_SOURCE=wiki_exports_only

# Routes admin HTTP en mode legacy (défaut: false)
# Si true → laisse passer downstream + audit log JSON-line + Prometheus counter
# DOIT être accompagné des 3 variables ci-dessous (sinon refus boot par Pydantic).
RAG_LEGACY_ADMIN_ENABLED=false

# Date de Sunset des routes admin (J0 + 30j). Format YYYY-MM-DD.
RAG_ADMIN_SUNSET_AT=2026-06-03

# Encadrement strict du mode legacy (anti-permanence — refus boot si manquant/invalide)
# Obligatoire SI rag_legacy_admin_enabled=true OU rag_write_mode=legacy
# RAG_LEGACY_REASON=INC-2026-099                         # cite INC-/P0-/P1-
# RAG_LEGACY_EXPIRES_AT=2026-05-15T00:00:00Z             # ISO-8601, ≤ +14j
# RAG_LEGACY_AUTHORIZED_BY=@reviewer                     # GitHub handle (G3)

# Audit log path (défaut: /var/log/automecanik-rag/audit-legacy-admin.jsonl)
# Permissions : rag:rag 0640, group rag-readers pour ops/Loki/Vector. Rotation 90j.
# RAG_AUDIT_LOG_PATH=/var/log/automecanik-rag/audit-legacy-admin.jsonl
